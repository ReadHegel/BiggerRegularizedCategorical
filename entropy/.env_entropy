export USER="hegel"
export STORAGE="/storage_nvme_1/$USER"
export REPO_PATH="$HOME/repos/BiggerRegularizedCategorical"
export ENV_NAME="venv_bigger_reg"

export HF_HOME="$STORAGE/cache/huggingface"
export PIP_CACHE_DIR="$STORAGE/cache/pip_cache"
export TRITON_CACHE_DIR="$STORAGE/cache/triton_cache"
export WANDB_CACHE_DIR="$STORAGE/cache/wandb_cache"
export UV_CACHE_DIR="$STORAGE/.uv_cache"
export UV_PROJECT_ENVIRONMENT="$STORAGE/$ENV_NAME"

export PATH="$HOME/.local/bin:$PATH"
export PATH="/usr/local/cuda/bin:$PATH"
export CUDA_ROOT="/usr/local/cuda/bin"

# Link the venv in $STORAGE to local path 
export VENV_LOCAL="$REPO_PATH/.venv"
mkdir -p "$UV_PROJECT_ENVIRONMENT"
ln -sf "$UV_PROJECT_ENVIRONMENT" "$VENV_LOCAL"